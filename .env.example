TAAPI_API_KEY=your_taapi_key_here  # From https://taapi.io
# 64-char hex private key (0x prefix optional). Do not leave the placeholder value.
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_NETWORK=mainnet
OPENROUTER_API_KEY=your_openrouter_key_here  # From https://openrouter.ai
ASSETS="BTC ETH SOL BNB ZEC EIGEN"
INTERVAL="5m"

# LLM provider: "openrouter" (default) or "ollama"
LLM_PROVIDER=openrouter
LLM_MODEL="x-ai/grok-4"

# Ollama settings (only needed when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional OpenRouter headers
# OPENROUTER_REFERER=https://your-site.com
# OPENROUTER_APP_TITLE=trading-agent

# Optional model overrides / provider hints
# SANITIZE_MODEL=openai/gpt-5
# REASONING_ENABLED=false
# REASONING_EFFORT=high
# PROVIDER_CONFIG={"order":["Together"],"ignore":["Nebius"]}
# PROVIDER_QUANTIZATIONS=["int8","fp16"]
# ENABLE_LLM_TOOLS=true

# Risk controls
MAX_ALLOCATION_PCT=20
MAX_POSITIONS=10
MIN_FREE_COLLATERAL_PCT=20
DAILY_LOSS_HALT_PCT=10

# Optional Redis cache (omit or REDIS_ENABLED=false for in-memory + disk only)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_ENABLED=true

# Storage / logging
DATA_DIR=.data
LOG_DIR=logs
