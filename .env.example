TAAPI_API_KEY=your_taapi_key_here  # From https://taapi.io
# 64-char hex private key (0x prefix optional). Do not leave the placeholder value.
HYPERLIQUID_PRIVATE_KEY=
HYPERLIQUID_NETWORK=mainnet

# Ollama cloud or self-hosted endpoint
OLLAMA_BASE_URL=https://api.ollama.com/v1
OLLAMA_MODEL=llama3.1:8b
# Required if your Ollama provider requires bearer token auth (cloud, proxy, etc.)
OLLAMA_API_KEY=

ASSETS="BTC ETH SOL BNB ZEC EIGEN"
INTERVAL="5m"

# Optional tool calling for dynamic TAAPI indicators (disabled by default)
# ENABLE_LLM_TOOLS=false

# Risk controls
MAX_ALLOCATION_PCT=20
MAX_POSITIONS=10
MIN_FREE_COLLATERAL_PCT=20
DAILY_LOSS_HALT_PCT=10

# Optional Redis cache (omit or REDIS_ENABLED=false for disk only)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_ENABLED=true

# Storage / logging
DATA_DIR=.data
LOG_DIR=logs
